import numpy as np
import scipy.linalg as la


# ============================================================
# RELATIONAL LYSIS ENGINE
# ============================================================

class RelationalLysisEngine:

    def __init__(self, tol=1e-12, max_depth=10):
        self.tol = tol
        self.max_depth = max_depth

    def decompose(self, state):
        D = 0.5 * (state + state.T)
        S = 0.5 * (state - state.T)
        return D, S

    def step(self, sigma):
        D, S = sigma
        next_D, next_S = self.decompose(D)
        return (next_D, next_S)

    def run(self, initial_state):

        sigma = self.decompose(initial_state)

        for depth in range(self.max_depth):

            D, S = sigma

            next_sigma = self.step(sigma)

            delta = np.linalg.norm(next_sigma[0] - D)

            if delta < self.tol:
                return next_sigma, depth + 1, True

            sigma = next_sigma

        return sigma, self.max_depth, False


# ============================================================
# SCALE GENERATOR
# ============================================================

def generate_scaled_state(N):

    x = np.linspace(0, 2*np.pi, N)

    A = np.zeros((N, N))

    for i in range(N):
        for j in range(N):
            A[i, j] = np.sin(x[i] - x[j])

    noise = np.random.randn(N, N) * 0.05

    return A + noise


# ============================================================
# EMERGENT OPERATOR
# ============================================================

def emergent_operator(D):

    degree = np.diag(np.sum(np.abs(D), axis=1))
    L = degree - D

    return L


# ============================================================
# INVARIANTS
# ============================================================

def operator_invariants(L):

    evals = la.eigvalsh(L)

    min_eval = np.min(evals)
    max_eval = np.max(evals)

    trace = np.trace(L)

    ratio = max_eval / (min_eval + 1e-12)

    return min_eval, max_eval, trace, ratio


# ============================================================
# EXPERIMENT
# ============================================================

def run_experiment():

    print("\nRELATIONAL LYSIS — RENORMALIZATION TOWER INVARIANCE (UPDATED)")
    print("------------------------------------------------------------")

    np.random.seed(0)

    engine = RelationalLysisEngine()

    scales = [100, 200, 400, 800]

    trace_norm_N2 = []
    trace_norm_D = []
    spectral_ratios = []

    for N in scales:

        print(f"\n[*] Scale N = {N}")

        state = generate_scaled_state(N)

        sigma, depth, converged = engine.run(state)

        if not converged:
            print(" FAIL: No convergence")
            continue

        D, S = sigma

        print(" Converged Depth:", depth)
        print(" Diamond Norm:", np.linalg.norm(D))

        L = emergent_operator(D)

        min_eval, max_eval, trace, ratio = operator_invariants(L)

        # -----------------------------
        # RL-consistent normalizations
        # -----------------------------

        norm_trace_N2 = trace / (N**2)
        norm_trace_D = trace / (np.linalg.norm(D) + 1e-12)

        trace_norm_N2.append(norm_trace_N2)
        trace_norm_D.append(norm_trace_D)
        spectral_ratios.append(ratio)

        print(" Min Eigenvalue:", min_eval)
        print(" Max Eigenvalue:", max_eval)
        print(" Trace:", trace)
        print(" Trace / N^2:", norm_trace_N2)
        print(" Trace / ||D||:", norm_trace_D)
        print(" Spectral Ratio:", ratio)

    # ========================================================
    # SCALE COMPARISON
    # ========================================================

    print("\n------------------------------------------------------------")
    print("SCALE COMPARISON")

    for i, N in enumerate(scales):
        print(f"N={N} → trace/N^2 {trace_norm_N2[i]} | trace/||D|| {trace_norm_D[i]}")

    # Deterministic dispersion (not probabilistic inference)
    var_N2 = np.max(trace_norm_N2) - np.min(trace_norm_N2)
    var_D = np.max(trace_norm_D) - np.min(trace_norm_D)

    print("\nDispersion Trace/N^2:", var_N2)
    print("Dispersion Trace/||D||:", var_D)

    print("\nINTERPRETATION:")
    print("Stable normalized invariants across scale → RL scale universality.")


# ============================================================

if __name__ == "__main__":
    run_experiment()
